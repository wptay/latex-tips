\newcounter{newdocumentimport}
\newcommand{\labelimport}{%
  \stepcounter{newdocumentimport}%
  \def\label@in@display##1{%
    \xrcounterref{equation}{##1}%
    \oldlabel@in@display{\docprefix\thenewdocumentimport-##1}%
  }%
  \def\label##1{%
    \oldlabel{\docprefix\thenewdocumentimport-##1}%
  }%
}

\newcommand{\revisionframe}[1]{
  \begingroup
  \par%
  \begin{mdframed}[userdefinedwidth=0.98\linewidth,align=center]%
    \labelimport%
    \ExecuteMetaData[\maintext]{#1}%
  \end{mdframed}%
  \endgroup
}

%\makeatother

% Usage example: 
% If the tex that you transfer over using \revision contains a \label{thmname} for an environment (e.g., Theorem, Lemma, Definition, table, figure), it will not have the same numbering as that in \maintext. 
% Call \xrcounterref{environment_name}{thmname} before \revision to fix this. 
\newcommand{\xrcounterref}[2]{
  \edef\x{\getrefnumber{#2}}%
  \expandafter\ifrmnum\expandafter{\x}{%
    \setcounter{#1}{\expandafter\rmntonum\expandafter{\x}}%
  }{%
    \setcounter{#1}{\getrefnumber{#2}}
  }
  %\setcounter{#1}{\getrefnumber{#2}}
  \addtocounter{#1}{-1}
}

\DeclareDocumentCommand{\xrcounters}{ >{\SplitArgument{1}{>}} m }{%
  \xrcounterref #1
}

% Starred version to copy using \copybox, see below.
\DeclareDocumentCommand{\revision}{ s m >{\SplitList{;}} o }{%
  \setcounter{eqcounter}{\value{equation}}%
  \setcounter{figcounter}{\value{figure}}%
  \setcounter{tabcounter}{\value{table}}%
  \begingroup
    % Locally patch figure and table to always use [H] inside the box
    \let\origfigure\figure
    \let\endorigfigure\endfigure
    \renewenvironment{figure}[1][]%
      {\origfigure[H]}%
      {\endorigfigure}
    \let\origtable\table
    \let\endorigtable\endtable
    \renewenvironment{table}[1][]%
      {\origtable[H]}%
      {\endorigtable}
    % Change back the numbering to arabic
    \renewcommand{\theequation}{\arabic{equation}}%
    \renewcommand{\thefigure}{\arabic{figure}}%
    \renewcommand{\thetable}{\Roman{table}}%
    % Process the optional argument list of environment names and labels
    \IfValueT{#3}{%
      \ProcessList {#3}{%
        \xrcounters
      }%
    }
    \IfBooleanTF{#1}{%
      \copybox{#2}%
    }{%
      \revisionframe{#2}%
    }%
  \endgroup
  \setcounter{equation}{\value{eqcounter}}%
  \setcounter{figure}{\value{figcounter}}%  
  \setcounter{table}{\value{tabcounter}}%
}

% Read the clipboard package documentation for more details.
% For the cases that are not supported by catchfilebetweentags. May not be necessary now with the patch \patchcmd{\CatchFBT@Fin@l}.
% Need to include the following in the main file preamble:
% \RequirePackage{clipboard}
% \newclipboard{output-myclipboard}
% Ensure that the main file is compiled first and check that output-myclipboard.cpy file has content.
\RequirePackage{clipboard}
\newcommand{\copybox}[1]{%
  \openclipboard{output-myclipboard}
  \begin{mdframed}[
    userdefinedwidth=0.98\linewidth,
    align=center,
    skipabove=0.5em,       % Space above the box
    skipbelow=0.5em,       % Space below the box
    innertopmargin=6pt,    % Inner padding
    innerbottommargin=6pt,
    innerleftmargin=10pt,
    innerrightmargin=10pt,
    linewidth=0.5pt,       % Border thickness
    frametitlealignment=center % Title alignment (if used)
  ]
  \Paste{#1}%
  \end{mdframed}%
}

